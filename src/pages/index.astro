---
import BaseLayout from '../layouts/BaseLayout.astro';
import products from '../data/products.json';
import { translateProductName } from '../data/i18n.js';
import { toJPY } from '../data/jpyRate.js';

const featured = products.slice(0, 8).map((p) => ({ ...p, jpName: translateProductName(p.name), jpy: toJPY(p.price_usd) }));
const storyWatch = featured[5] || featured[0];
const brands = [...new Set(products.map((p) => p.brand).filter(Boolean))].slice(0, 8);
---

<BaseLayout title="時計物語" description="時計の物語、購入ガイド、CreationWatchesの価格リンクをまとめた編集型アフィリエイトサイト。">
  <section class="home-hero">
    <div class="container hero-grid">
      <div class="hero-copy">
        <p class="eyebrow">Editorial Affiliate Guides</p>
        <h1>時計を売る前に、選ぶ理由を語る。</h1>
        <p>
          時計物語は、モデルの背景、使う場面、価格帯、ブランドの魅力を物語として整理し、
          購入意欲の高い読者をCreationWatchesの価格確認へ案内します。
        </p>
        <div class="hero-actions">
          <a href="/watches" class="btn btn-primary">購入ガイドを読む</a>
          <a href="/monogatari/citizen-eco-drive.html" class="btn">物語を読む</a>
        </div>
      </div>

      {storyWatch && (
        <a href={storyWatch.url || '/watches'} class="hero-watch" target="_blank" rel="noopener noreferrer">
          <span>Story Spotlight</span>
          <img src={storyWatch.image} alt={storyWatch.jpName} />
          <strong>{storyWatch.jpName}</strong>
          <em>¥{storyWatch.jpy}</em>
          <small>CreationWatchesで価格を確認</small>
        </a>
      )}
    </div>
  </section>

  <section class="beliefs">
    <div class="container beliefs-grid">
      <div>
        <p class="eyebrow">StoreではなくFunnel</p>
        <h2>検索流入を、自然な購入クリックへ。</h2>
      </div>
      <div class="belief-list">
        <article><span>01</span><h3>物語</h3><p>時計の背景を語り、読者がそのモデルを理解できる入口を作ります。</p></article>
        <article><span>02</span><h3>選び方</h3><p>価格、用途、ブランド、デザインを整理し、購入前の迷いを減らします。</p></article>
        <article><span>03</span><h3>価格確認</h3><p>購入意欲が高まったタイミングでCreationWatchesへ送客します。</p></article>
      </div>
    </div>
  </section>

  <section class="featured">
    <div class="container">
      <div class="section-heading">
        <div>
          <p class="eyebrow">購入ガイド</p>
          <h2>読まれる時計、クリックされる時計</h2>
        </div>
        <a href="/watches" class="text-link">全{products.length}本を見る</a>
      </div>
      <div class="product-grid">
        {featured.map((product) => (
          <a href={product.url || '/watches'} class="product-card" target="_blank" rel="noopener noreferrer">
            <div class="product-image"><img src={product.image} alt={product.jpName} loading="lazy" /></div>
            <div class="product-info">
              <span>{product.brand}</span>
              <h3>{product.jpName}</h3>
              <strong>¥{product.jpy}</strong>
              <small>CreationWatchesで価格を確認</small>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="brand-strip">
    <div class="container">
      <p class="eyebrow">ブランド</p>
      <div class="brand-list">{brands.map((brand) => <span>{brand}</span>)}</div>
    </div>
  </section>
</BaseLayout>

<style>
  .home-hero { padding: 6rem 0; background: linear-gradient(180deg, var(--color-soft), var(--color-bg)); }
  .hero-grid { display: grid; grid-template-columns: minmax(0, 1.1fr) minmax(320px, 0.75fr); gap: 4rem; align-items: center; }
  .hero-copy p:not(.eyebrow) { max-width: 640px; margin-top: 1.25rem; color: var(--color-muted); font-size: 1rem; }
  .hero-actions { display: flex; flex-wrap: wrap; gap: 0.75rem; margin-top: 2rem; }
  .hero-watch { display: grid; gap: 0.55rem; min-height: 520px; padding: 2rem; color: inherit; text-decoration: none; background: var(--color-surface); border: 1px solid var(--color-border); }
  .hero-watch span, .product-info span { color: var(--color-gold); font-size: 0.66rem; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; }
  .hero-watch img { width: 100%; height: 320px; object-fit: contain; align-self: center; }
  .hero-watch strong { font-family: var(--font-serif); font-size: 1.08rem; font-weight: 400; line-height: 1.6; }
  .hero-watch em { color: var(--color-accent); font-family: var(--font-serif); font-size: 1.1rem; font-style: normal; }
  .hero-watch small, .product-info small { color: var(--color-muted); font-size: 0.7rem; font-weight: 700; letter-spacing: 0.04em; text-transform: uppercase; }
  .beliefs { padding: var(--spacing-xl) 0; background: var(--color-surface); }
  .beliefs-grid { display: grid; grid-template-columns: 0.8fr 1.2fr; gap: 4rem; align-items: start; }
  .belief-list { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1px; background: var(--color-border); }
  .belief-list article { min-height: 230px; padding: 1.5rem; background: var(--color-surface); }
  .belief-list span { display: block; margin-bottom: 2.5rem; color: var(--color-gold); font-family: var(--font-serif); font-size: 2rem; opacity: 0.45; }
  .belief-list p { margin-top: 0.75rem; color: var(--color-muted); font-size: 0.9rem; }
  .featured { padding: var(--spacing-xl) 0; }
  .section-heading { display: flex; justify-content: space-between; align-items: end; gap: 1.5rem; margin-bottom: 2rem; }
  .text-link { color: var(--color-accent); font-size: 0.82rem; font-weight: 700; letter-spacing: 0.06em; text-decoration: none; text-transform: uppercase; }
  .product-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1px; background: var(--color-border); border: 1px solid var(--color-border); }
  .product-card { display: flex; flex-direction: column; min-width: 0; color: inherit; text-decoration: none; background: var(--color-surface); }
  .product-image { display: grid; place-items: center; aspect-ratio: 1; padding: 1rem; background: #f7f3ed; }
  .product-image img { width: 100%; height: 100%; object-fit: contain; }
  .product-info { display: grid; gap: 0.35rem; padding: 1rem; }
  .product-info h3 { display: -webkit-box; min-height: 3.4em; overflow: hidden; font-family: var(--font-sans); font-size: 0.86rem; font-weight: 400; line-height: 1.7; -webkit-line-clamp: 2; -webkit-box-orient: vertical; }
  .product-info strong { color: var(--color-accent); font-family: var(--font-serif); font-size: 1rem; }
  .brand-strip { padding: 4rem 0; background: var(--color-surface); border-block: 1px solid var(--color-border); }
  .brand-list { display: flex; flex-wrap: wrap; gap: 0.75rem; margin-top: 1.5rem; }
  .brand-list span { border: 1px solid var(--color-border); padding: 0.55rem 0.85rem; background: var(--color-bg); color: var(--color-subtle); font-size: 0.85rem; }
  @media (max-width: 980px) { .hero-grid, .beliefs-grid { grid-template-columns: 1fr; } .product-grid { grid-template-columns: repeat(2, 1fr); } .belief-list { grid-template-columns: 1fr; } }
  @media (max-width: 560px) { .home-hero { padding: 4rem 0; } .hero-watch { padding: 1rem; } .product-grid { grid-template-columns: 1fr; } .section-heading { flex-direction: column; align-items: start; } }
</style>
