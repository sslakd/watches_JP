---
import BaseLayout from '../layouts/BaseLayout.astro';
import products from '../data/products.json';

const brands = [...new Set(products.map((p) => p.brand).filter(Boolean))].slice(0, 8);
const stories = [
  {
    kicker: '光をまとう',
    title: 'シチズン エコ・ドライブ',
    copy: '光を動力へ変える技術。その静かな革新が、日常の時間を支え続けます。',
    href: '/monogatari/citizen-eco-drive.html',
    image: '/images/watches/CA4560-81E-transparent.webp',
    alt: 'シチズン エコ・ドライブ CA4560-81E',
  },
  {
    kicker: '日本製の矜持',
    title: 'オリエントスター',
    copy: '見えない部分にこそ手をかける。日本の時計づくりが宿す、誠実さの物語。',
    href: '/monogatari/orient-star-power-reserve.html',
    image: '/images/watches/RE-AU0001S00B-transparent.webp',
    alt: 'オリエントスター パワーリザーブ',
  },
  {
    kicker: '陸のための設計',
    title: 'セイコー プロスペックス',
    copy: '方角を読み、環境に応える。道具として生まれた時計が、旅の記憶になるまで。',
    href: '/monogatari/seiko-srpd31j1.html',
    image: '/images/watches/SRPD31J1-transparent.webp',
    alt: 'セイコー プロスペックス SRPD31J1',
  },
];
---

<BaseLayout title="時計物語" description="時計の背景、技術、佇まいを物語として届ける日本の時計メディア。">
  <section class="journey-hero">
    <div class="hero-watch" aria-hidden="true"></div>
    <div class="hero-shade"></div>
    <div class="container hero-content">
      <p class="hero-kicker">時計と出会う、もうひとつの方法</p>
      <h1>もしかすると、心に残る物語が、次の一本を選ぶ。</h1>
      <p class="hero-intro">技術、背景、つくり手の思想。時計が刻んできた時間を知ってから、自分の時間へ迎える。</p>
      <a href="/monogatari/citizen-eco-drive.html" class="light-link">物語を読む <span>→</span></a>
    </div>
    <a href="#philosophy" class="hero-next">物語のはじまり <span>↓</span></a>
  </section>

  <section class="philosophy" id="philosophy">
    <div class="container philosophy-inner">
      <p class="section-kicker">時計物語の考え方</p>
      <h2>見る。知る。自分の時間を重ねる。</h2>
      <p>時計選びは、数字だけの比較ではありません。最初にその姿と出会い、背景にある物語を知り、最後に自分の暮らしへ置いてみる。時計物語は、その静かな順序を大切にします。</p>
      <div class="journey-steps">
        <span>一 — 出会う</span>
        <span>二 — 読む</span>
        <span>三 — 選ぶ</span>
      </div>
    </div>
  </section>

  <section class="stories" id="stories">
    <header class="container stories-heading">
      <p class="section-kicker">選ばれた物語</p>
      <h2>時間の向こうに、景色がある時計。</h2>
    </header>

    {stories.map((story, index) => (
      <article class:list={['story-chapter', { reverse: index % 2 === 1 }]}>
        <a href={story.href} class="chapter-image">
          <img src={story.image} alt={story.alt} loading={index === 0 ? 'eager' : 'lazy'} />
        </a>
        <div class="chapter-copy">
          <p class="section-kicker">{story.kicker}</p>
          <h3>{story.title}</h3>
          <p>{story.copy}</p>
          <a href={story.href} class="ink-link">物語を読む <span>→</span></a>
        </div>
      </article>
    ))}
  </section>

  <section class="promise">
    <div class="container promise-grid">
      <div>
        <p class="section-kicker">物語から選ぶ理由</p>
        <h2>細部に宿るものを、丁寧に。</h2>
      </div>
      <div class="promise-list">
        <div><span>背景</span><p>ブランド、土地、時代が時計へ残したもの。</p></div>
        <div><span>佇まい</span><p>仕様表だけでは伝わらない、身につけたときの気配。</p></div>
        <div><span>選択</span><p>物語を読んだあとにだけ、現在の価格へ案内します。</p></div>
      </div>
    </div>
  </section>

  <section class="brands">
    <div class="container">
      <p class="section-kicker">ブランドを越えて</p>
      <div class="brand-line">{brands.map((brand) => <span>{brand}</span>)}</div>
    </div>
  </section>

  <section class="closing">
    <div class="container closing-inner">
      <p class="section-kicker">次の物語へ</p>
      <h2>次の一本は、ひとつの物語から始まるかもしれません。</h2>
      <a href="/watches" class="light-link">時計を探す <span>→</span></a>
    </div>
  </section>
</BaseLayout>

<style>
  .container { width: min(1180px, calc(100% - 2rem)); margin: 0 auto; }
  .journey-hero {
    position: relative;
    min-height: min(860px, calc(100vh - 72px));
    overflow: hidden;
    display: flex;
    align-items: end;
    color: #fff;
    background: #293a36;
  }
  .hero-watch {
    position: absolute;
    inset: 0;
    background:
      url("/images/watches/CA4560-81E-transparent.webp")
      right 10% center / auto 92% no-repeat,
      linear-gradient(105deg, #253632 0%, #3e534d 55%, #d9ded8 55%, #f1f2ef 100%);
    transform: scale(1.01);
  }
  .hero-shade { position: absolute; inset: 0; background: linear-gradient(90deg, rgba(9,20,17,.58), transparent 72%); }
  .hero-content { position: relative; z-index: 1; padding-bottom: 4.5rem; }
  .hero-content h1 { max-width: 800px; font-size: 4rem; line-height: 1.2; }
  .hero-kicker, .section-kicker { margin: 0 0 1.4rem; font-size: .68rem; font-weight: 700; letter-spacing: .18em; text-transform: uppercase; }
  .hero-intro { max-width: 590px; margin-top: 1.8rem; font-size: 1rem; line-height: 2; }
  .light-link, .ink-link {
    display: inline-flex;
    gap: 1.2rem;
    align-items: center;
    margin-top: 2rem;
    padding-bottom: .45rem;
    border-bottom: 1px solid currentColor;
    text-decoration: none;
    font-size: .74rem;
    font-weight: 700;
    letter-spacing: .12em;
    color: inherit;
  }
  .hero-next { position: absolute; z-index: 2; left: 50%; bottom: 2.2rem; display: flex; gap: 1rem; color: #fff; font-size: .68rem; letter-spacing: .14em; text-decoration: none; transform: translateX(-50%); }
  .philosophy { padding: clamp(7rem, 13vw, 12rem) 0; text-align: center; background: #f5f1e9; }
  .philosophy-inner { max-width: 900px; }
  .philosophy h2, .stories-heading h2, .promise h2, .closing h2 { font-size: 3.8rem; line-height: 1.35; }
  .philosophy-inner > p:not(.section-kicker) { max-width: 700px; margin: 2rem auto 0; color: var(--color-subtle); font-size: 1rem; line-height: 2.1; }
  .journey-steps { display: flex; justify-content: center; gap: 3rem; margin-top: 3.5rem; color: var(--color-gold); font-size: .72rem; font-weight: 700; letter-spacing: .12em; }
  .stories { padding: 8rem 0 0; background: #fff; }
  .stories-heading { margin-bottom: 5rem; text-align: center; }
  .story-chapter { display: grid; grid-template-columns: 58% 42%; min-height: 650px; }
  .story-chapter.reverse { grid-template-columns: 42% 58%; }
  .story-chapter.reverse .chapter-image { order: 2; }
  .chapter-image { overflow: hidden; display: grid; place-items: center; background: #edf0ec; }
  .chapter-image img { width: 70%; height: 70%; object-fit: contain; transition: transform .7s ease; }
  .chapter-image:hover img { transform: scale(1.05); }
  .chapter-copy { display: flex; flex-direction: column; justify-content: center; padding: clamp(3rem, 7vw, 8rem); background: #e6dfd3; }
  .story-chapter.reverse .chapter-copy { background: #293a36; color: #fff; }
  .chapter-copy h3 { max-width: 600px; font-size: 3.5rem; line-height: 1.3; }
  .chapter-copy > p:not(.section-kicker) { max-width: 480px; margin-top: 1.5rem; font-size: .96rem; line-height: 2; }
  .promise { padding: clamp(7rem, 11vw, 10rem) 0; background: #f5f1e9; }
  .promise-grid { display: grid; grid-template-columns: .9fr 1.1fr; gap: 7rem; }
  .promise-list { border-top: 1px solid #cec5b6; }
  .promise-list div { display: grid; grid-template-columns: 110px 1fr; gap: 2rem; padding: 1.5rem 0; border-bottom: 1px solid #cec5b6; }
  .promise-list span { font-family: var(--font-serif); font-size: 1.2rem; }
  .promise-list p { color: var(--color-muted); }
  .brands { padding: 4rem 0; background: #fff; text-align: center; }
  .brand-line { display: flex; flex-wrap: wrap; justify-content: center; gap: 1.4rem 3rem; color: #57534d; font-family: var(--font-serif); font-size: 1.1rem; }
  .closing { min-height: 620px; display: grid; place-items: center; color: #fff; text-align: center; background: #293a36; }
  .closing-inner { max-width: 900px; }
  @media (max-width: 800px) {
    .journey-hero { min-height: 780px; }
    .hero-watch { background-position: center 16%; background-size: 330px auto, cover; }
    .hero-shade { background: linear-gradient(0deg, rgba(12,24,21,.9) 0%, rgba(12,24,21,.08) 72%); }
    .hero-content { padding-bottom: 7rem; }
    .hero-content h1 { font-size: 3rem; }
    .philosophy h2, .stories-heading h2, .promise h2, .closing h2 { font-size: 2.5rem; }
    .chapter-copy h3 { font-size: 2.5rem; }
    .journey-steps { gap: 1rem; flex-wrap: wrap; }
    .story-chapter, .story-chapter.reverse { grid-template-columns: 1fr; min-height: 0; }
    .story-chapter.reverse .chapter-image { order: 0; }
    .chapter-image { min-height: 430px; }
    .chapter-copy { min-height: 440px; padding: 3rem 1.5rem; }
    .promise-grid { grid-template-columns: 1fr; gap: 3rem; }
    .promise-list div { grid-template-columns: 1fr; gap: .4rem; }
  }
</style>
