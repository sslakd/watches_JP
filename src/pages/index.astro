---
import BaseLayout from '../layouts/BaseLayout.astro';
import products from '../data/products.json';
const featured = products.slice(0, 4);
const luxury = products.filter(p => p.price_usd > 300).slice(0, 4);
const affordable = products.filter(p => p.price_usd <= 200).slice(0, 4);
const storyWatch = products[5];
---
<BaseLayout title="時計物語" description="すべての時計に物語がある。時計は単なる道具ではなく、あなたの人生の大切な瞬間に寄り添う存在です。">
  <!-- Hero Section — Full Bleed -->
  <section class="hero-full">
    <div class="hero-content">
      <div class="hero-kicker">— 時計物語へようこそ —</div>
      <h1>すべての時計に<br>物語がある</h1>
      <p class="hero-text">時計は、時を刻むための道具ではありません。<br>
      それは、あなたの人生の特別な瞬間を刻む、<br>
      かけがえのない物語の証です。</p>
      <a href="/watches" class="btn-hero">時計たちの物語を読む</a>
    </div>
    <div class="hero-visual">
      <div class="hero-ornament"></div>
    </div>
  </section>

  <!-- Philosophy Section -->
  <section class="philosophy">
    <div class="philosophy-inner">
      <div class="philosophy-label">私たちの信念</div>
      <h2>なぜ「物語」なのか？</h2>
      <div class="philosophy-grid">
        <div class="belief-card">
          <div class="belief-number">01</div>
          <h3>受け継ぐ</h3>
          <p>祖父から孫へ。時計は世代を超えて語り継がれる、家族の物語です。一本の時計に刻まれた時間は、あなただけのものです。</p>
        </div>
        <div class="belief-card">
          <div class="belief-number">02</div>
          <h3>出会う</h3>
          <p>初めての機械式、昇進の記念、結婚記念日。時計は人生の節目に寄り添い、その瞬間を永遠にします。</p>
        </div>
        <div class="belief-card">
          <div class="belief-number">03</div>
          <h3>生きる</h3>
          <p>セイコー、シチズン、カシオ、オリエント。日本が誇る時計ブランドの一つひとつに、技術者たちの熱い物語があります。</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Featured Story (First Watch) -->
  <section class="story-feature">
    <div class="story-inner">
      <div class="story-image">
        <img src={storyWatch.image} alt={storyWatch.name} />
      </div>
      <div class="story-text">
        <div class="story-kicker">今日の一本</div>
        <h2>{storyWatch.brand} の物語</h2>
        <p class="story-desc">{storyWatch.description}</p>
        <div class="story-meta">
          <span class="story-price">${storyWatch.price_usd.toLocaleString()}</span>
          <a href={`/watches/${storyWatch.sku}`} class="btn-story">この物語を読む →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Collection Section — Curated Stories -->
  <section class="collection">
    <div class="collection-header">
      <div class="section-label">Collection</div>
      <h2>厳選された<br>時計たちの物語</h2>
    </div>

    <div class="collection-grid">
      {products.slice(0, 12).map((product, i) => (
        <a href={`/watches/${product.sku}`} class="story-card" style={`--delay: ${i * 0.05}s`}>
          <div class="story-card-image">
            <img src={product.image} alt={product.name} loading="lazy" />
            <div class="story-card-overlay"></div>
          </div>
          <div class="story-card-info">
            <div class="story-card-brand">{product.brand}</div>
            <h3>{product.name.length > 40 ? product.name.slice(0, 40) + '…' : product.name}</h3>
            <div class="story-card-footer">
              <span class="story-card-price">${product.price_usd.toLocaleString()}</span>
              <span class="story-card-link">物語を読む →</span>
            </div>
          </div>
        </a>
      ))}
    </div>
    <div class="collection-cta">
      <a href="/watches" class="btn-outline">すべての時計を見る — {products.length}本の物語</a>
    </div>
  </section>

  <!-- Brand Stories -->
  <section class="brands-section">
    <div class="section-label">ブランド</div>
    <h2>日本が誇る<br>時計ブランド</h2>
    <div class="brands-showcase">
      {['Seiko','Citizen','Casio','Orient'].map(brand => {
        const brandWatches = products.filter(p => p.brand === brand).slice(0, 3);
        if (brandWatches.length === 0) return null;
        return (
          <div class="brand-group">
            <h3>{brand}</h3>
            <div class="brand-mini-grid">
              {brandWatches.map(w => (
                <a href={`/watches/${w.sku}`} class="brand-mini-card">
                  <img src={w.image} alt={w.name} loading="lazy" />
                  <span>${w.price_usd.toLocaleString()}</span>
                </a>
              ))}
            </div>
          </div>
        );
      })}
    </div>
  </section>

  <!-- CTA Final -->
  <section class="cta-final">
    <div class="cta-inner">
      <div class="cta-kicker">時計物語</div>
      <h2>あなたの物語を<br>見つけてください</h2>
      <p>一本の時計には、一つの物語があります。<br>あなたの次の物語を、見つけに来てください。</p>
      <a href="/watches" class="btn-hero">時計を探す</a>
    </div>
  </section>
</BaseLayout>

<style>
  /* Full-width sections — no container constraints */
  section { width: 100%; }

  /* ===== HERO ===== */
  .hero-full {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 90vh;
    position: relative;
    overflow: hidden;
  }
  .hero-content {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 8rem 4rem 4rem;
    max-width: 600px;
    margin-left: auto;
  }
  .hero-kicker {
    font-size: 0.65rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--color-gold);
    margin-bottom: 1.5rem;
    font-weight: 500;
  }
  .hero-content h1 { margin-bottom: 1.5rem; }
  .hero-text {
    font-size: 0.9rem;
    color: var(--color-muted);
    line-height: 2.2;
    margin-bottom: 2.5rem;
  }
  .btn-hero {
    display: inline-flex;
    align-items: center;
    background: var(--color-text);
    color: white;
    padding: 0.9rem 2.5rem;
    text-decoration: none;
    font-size: 0.8rem;
    letter-spacing: 0.1em;
    transition: all 0.3s;
    font-family: var(--font-sans);
    align-self: flex-start;
  }
  .btn-hero:hover { background: var(--color-accent); transform: translateY(-2px); }

  .hero-visual {
    background: linear-gradient(135deg, #1a1a1a 0%, #2c2c2c 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
  }
  .hero-ornament {
    width: 400px;
    height: 400px;
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 50%;
    position: relative;
  }
  .hero-ornament::before {
    content: "時計物語";
    position: absolute;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    font-family: var(--font-serif);
    color: rgba(255,255,255,0.04);
    font-size: 3rem;
    letter-spacing: 0.3em;
    white-space: nowrap;
  }

  /* ===== PHILOSOPHY ===== */
  .philosophy { background: white; padding: var(--spacing-2xl) 2rem; }
  .philosophy-inner { max-width: 1100px; margin: 0 auto; }
  .philosophy-label {
    font-size: 0.65rem; letter-spacing: 0.25em; color: var(--color-gold);
    text-transform: uppercase; margin-bottom: 0.5rem; font-weight: 500;
  }
  .philosophy h2 { margin-bottom: var(--spacing-xl); }
  .philosophy-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 2.5rem; }
  .belief-card { padding: 0; }
  .belief-number {
    font-family: var(--font-serif);
    font-size: 2.5rem;
    color: var(--color-gold);
    opacity: 0.3;
    margin-bottom: 0.5rem;
    line-height: 1;
  }
  .belief-card h3 { font-size: 1rem; margin-bottom: 0.8rem; font-weight: 600; }
  .belief-card p { font-size: 0.82rem; color: var(--color-muted); line-height: 2; }

  /* ===== STORY FEATURE ===== */
  .story-feature {
    background: var(--color-text);
    color: white;
    padding: 0;
  }
  .story-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    max-width: 1200px;
    margin: 0 auto;
  }
  .story-image {
    display: flex;
    align-items: center;
    justify-content: center;
    background: #2a2a2a;
    padding: 4rem;
  }
  .story-image img {
    max-width: 80%;
    max-height: 400px;
    object-fit: contain;
    filter: drop-shadow(0 20px 40px rgba(0,0,0,0.5));
  }
  .story-text { padding: 4rem; display: flex; flex-direction: column; justify-content: center; }
  .story-kicker {
    font-size: 0.6rem; letter-spacing: 0.3em; color: var(--color-gold);
    text-transform: uppercase; margin-bottom: 0.5rem;
  }
  .story-text h2 { margin-bottom: 1rem; color: white; }
  .story-desc { font-size: 0.85rem; color: rgba(255,255,255,0.7); line-height: 2; margin-bottom: 1.5rem; }
  .story-meta { display: flex; align-items: center; gap: 1.5rem; }
  .story-price { font-family: var(--font-serif); font-size: 1.2rem; color: var(--color-gold); }
  .btn-story {
    color: white; text-decoration: none;
    font-size: 0.78rem; border-bottom: 1px solid rgba(255,255,255,0.3);
    padding-bottom: 0.2rem; transition: all 0.3s;
  }
  .btn-story:hover { border-color: var(--color-gold); color: var(--color-gold); }

  /* ===== COLLECTION ===== */
  .collection { padding: var(--spacing-2xl) 2rem; }
  .collection-header { max-width: 1200px; margin: 0 auto var(--spacing-xl); }
  .section-label {
    font-size: 0.65rem; letter-spacing: 0.25em; color: var(--color-gold);
    text-transform: uppercase; margin-bottom: 0.3rem; font-weight: 500;
  }
  .collection-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    background: var(--color-border);
    max-width: 1200px;
    margin: 0 auto;
  }
  .story-card {
    position: relative;
    text-decoration: none;
    color: inherit;
    background: var(--color-card-bg);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    animation: fadeIn 0.6s ease both;
    animation-delay: var(--delay, 0s);
  }
  @keyframes fadeIn { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }

  .story-card-image {
    position: relative;
    aspect-ratio: 1;
    overflow: hidden;
    background: #f5f0e8;
  }
  .story-card-image img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    padding: 1rem;
    transition: transform 0.6s;
  }
  .story-card:hover .story-card-image img { transform: scale(1.08); }
  .story-card-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, transparent 60%, rgba(0,0,0,0.03));
    opacity: 0;
    transition: opacity 0.4s;
  }
  .story-card:hover .story-card-overlay { opacity: 1; }

  .story-card-info { padding: 1rem 1.2rem 1.2rem; flex: 1; display: flex; flex-direction: column; }
  .story-card-brand {
    font-size: 0.6rem; letter-spacing: 0.1em; color: var(--color-gold);
    text-transform: uppercase; font-weight: 600; margin-bottom: 0.3rem;
  }
  .story-card-info h3 {
    font-size: 0.82rem; font-weight: 400;
    line-height: 1.5; margin-bottom: 0.5rem; flex: 1;
  }
  .story-card-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .story-card-price {
    font-family: var(--font-serif);
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--color-accent);
  }
  .story-card-link {
    font-size: 0.7rem; color: var(--color-muted);
    transition: color 0.3s;
  }
  .story-card:hover .story-card-link { color: var(--color-accent); }

  .collection-cta {
    text-align: center;
    padding: var(--spacing-xl) 0 0;
  }
  .btn-outline {
    display: inline-block;
    border: 1px solid var(--color-text);
    padding: 0.8rem 2.5rem;
    text-decoration: none;
    color: var(--color-text);
    font-size: 0.78rem;
    letter-spacing: 0.08em;
    transition: all 0.3s;
    font-family: var(--font-sans);
  }
  .btn-outline:hover { background: var(--color-text); color: white; }

  /* ===== BRANDS ===== */
  .brands-section {
    background: white;
    padding: var(--spacing-2xl) 2rem;
  }
  .brands-section > .section-label,
  .brands-section > h2 {
    max-width: 1200px;
    margin-left: auto;
    margin-right: auto;
  }
  .brands-showcase {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2rem;
    max-width: 1200px;
    margin: 0 auto;
  }
  .brand-group h3 {
    font-family: var(--font-serif);
    font-size: 0.9rem;
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--color-border);
    color: var(--color-gold);
  }
  .brand-mini-grid { display: flex; flex-direction: column; gap: 0.5rem; }
  .brand-mini-card {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    text-decoration: none;
    color: inherit;
    padding: 0.4rem;
    transition: background 0.2s;
    border-radius: 4px;
  }
  .brand-mini-card:hover { background: var(--color-overlay); }
  .brand-mini-card img {
    width: 50px; height: 50px;
    object-fit: contain;
    background: #f5f0e8;
    border-radius: 4px;
  }
  .brand-mini-card span {
    font-family: var(--font-serif);
    font-size: 0.78rem;
    color: var(--color-accent);
  }

  /* ===== CTA FINAL ===== */
  .cta-final {
    background: linear-gradient(135deg, #1a1a1a, #2c2c2c);
    color: white;
    text-align: center;
    padding: var(--spacing-2xl) 2rem;
  }
  .cta-inner { max-width: 600px; margin: 0 auto; }
  .cta-kicker {
    font-size: 0.6rem; letter-spacing: 0.3em; color: var(--color-gold);
    text-transform: uppercase; margin-bottom: 1rem;
  }
  .cta-final h2 { color: white; margin-bottom: 1rem; }
  .cta-final p { color: rgba(255,255,255,0.6); font-size: 0.9rem; margin-bottom: 2.5rem; }
  .cta-final .btn-hero { background: var(--color-gold); }
  .cta-final .btn-hero:hover { background: #a3842e; }

  /* ===== RESPONSIVE ===== */
  @media (max-width: 900px) {
    .hero-full { grid-template-columns: 1fr; min-height: auto; }
    .hero-content { padding: 6rem 2rem 3rem; max-width: 100%; }
    .hero-visual { height: 300px; }
    .philosophy-grid { grid-template-columns: 1fr; gap: 2rem; }
    .story-inner { grid-template-columns: 1fr; }
    .story-image { padding: 2rem; }
    .story-text { padding: 2rem; }
    .collection-grid { grid-template-columns: repeat(2, 1fr); }
    .brands-showcase { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 600px) {
    .collection-grid { grid-template-columns: 1fr; }
    .brands-showcase { grid-template-columns: 1fr; }
  }
</style>