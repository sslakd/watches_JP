---
import BaseLayout from '../../layouts/BaseLayout.astro';
import products from '../../data/products.json';
import { translateProductName, translateCategory, translateDescription } from '../../data/i18n.js';
import { toJPY } from '../../data/jpyRate.js';

export async function getStaticPaths() {
  return products.map((product) => ({
    params: { sku: product.sku },
    props: { product },
  }));
}

const { product } = Astro.props;
const sameBrand = products.filter(p => p.brand === product.brand && p.sku !== product.sku).slice(0, 6);
const samePrice = products.filter(p => Math.abs(p.price_usd - product.price_usd) < 50 && p.sku !== product.sku).slice(0, 3);
const relatedAll = [...sameBrand, ...samePrice].slice(0, 6).map(r => ({
  ...r,
  jpName: translateProductName(r.name),
  jpy: toJPY(r.price_usd),
}));
const randomQuote = [
  '「時は、誰にも平等に流れる。しかし、その刻み方は人それぞれだ。」',
  '「一本の時計が、一つの人生を変えることがある。」',
  '「正確さよりも大切なもの。それは、その時計が語る物語だ。」',
  '「時間を計るのではなく、時間を味わうために。」',
][Math.floor(Math.random() * 4)];
const specLines = [
  { label: 'ブランド', value: product.brand },
  { label: '型番', value: product.mpn },
  { label: 'SKU', value: product.sku },
  { label: 'カテゴリー', value: translateCategory(product.category) },
];
---
<BaseLayout title={`${product.brand} — "${translateProductName(product.name).slice(0, 50)}"`} description={translateDescription(product.description)}>
  <!-- Breadcrumb -->
  <nav class="breadcrumb">
    <a href="/">ホーム</a>
    <span>›</span>
    <a href="/watches">時計コレクション</a>
    <span>›</span>
    <span class="current">{product.brand}</span>
  </nav>

  <div class="story-detail">
    <!-- Left: The Watch -->
    <div class="watch-gallery">
      <div class="gallery-main">
        <img src={product.image} alt={translateProductName(product.name)} />
      </div>
    </div>

    <!-- Right: The Story -->
    <div class="watch-story">
      <!-- Atmosphere quote -->
      <div class="atmosphere-quote">{randomQuote}</div>

      <div class="brand-heading">{product.brand}</div>
      <h1 class="watch-title">{translateProductName(product.name).length > 70 ? translateProductName(product.name).slice(0, 70) + '…' : translateProductName(product.name)}</h1>

      <div class="price-row">
        <span class="price-current">¥{toJPY(product.price_usd)}</span>
        <span class="price-original">¥{toJPY(product.price_usd * 1.2)}</span>
        <span class="price-discount">-20%</span>
      </div>

      <!-- The Narrative -->
      <div class="narrative">
        <p>{translateDescription(product.description)}</p>
        <p class="narrative-extended">
          {product.brand}の技術と情熱が込められたこの一本。<br />
          日常の一瞬を特別に変える、そんな出会いをあなたに。
        </p>
      </div>

      <!-- Specs -->
      <div class="specs">
        <h3>時計の詳細</h3>
        <div class="specs-grid">
          {specLines.map(s => (
            <div class="spec-row">
              <span class="spec-label">{s.label}</span>
              <span class="spec-value">{s.value}</span>
            </div>
          ))}
        </div>
      </div>

      <!-- Action Buttons -->
      <div class="action-buttons">
        <button class="btn-add-cart">カートに入れる</button>
        <button class="btn-buy-now">今すぐ購入</button>
      </div>
      <div class="promo-banner">
        🚚 5000円以上で送料無料<br />
        30日以内返品可能
      </div>
    </div>
  </div>

  <!-- Related Stories -->
  {relatedAll.length > 0 && (
    <section class="related-stories">
      <div class="related-header">
        <div class="section-label">— 関連する物語 —</div>
        <h2>同じブランドの<br>もう一つの物語</h2>
      </div>
      <div class="related-grid">
        {relatedAll.map((r, i) => (
          <a href={`/watches/${r.sku}`} class="related-card" style={`--i: ${i}`}>
            <div class="related-img">
              <img src={r.image} alt={r.jpName} loading="lazy" />
            </div>
            <div class="related-info">
              <div class="related-brand">{r.brand}</div>
              <h4>{r.jpName.length > 35 ? r.jpName.slice(0, 35) + '…' : r.jpName}</h4>
              <span class="related-price">¥{r.jpy}</span>
            </div>
          </a>
        ))}
      </div>
    </section>
  )}

  <!-- Back CTA -->
  <div class="back-cta">
    <a href="/watches" class="btn-outline">← すべての時計に戻る</a>
  </div>
</BaseLayout>

<style>
  .breadcrumb {
    max-width: 1100px;
    margin: 2rem auto 0;
    padding: 1rem 2rem 0;
    font-size: 0.75rem;
    color: var(--color-muted);
  }
  .breadcrumb a { color: var(--color-muted); text-decoration: none; }
  .breadcrumb a:hover { color: var(--color-text); }
  .breadcrumb span { margin: 0 0.5rem; }
  .breadcrumb .current { color: var(--color-text); }

  .story-detail {
    display: grid;
    grid-template-columns: 1fr 1fr;
    max-width: 1100px;
    margin: 0 auto;
    padding: 2rem 2rem;
    gap: 3rem;
  }

  /* Gallery */
  .watch-gallery {}
  .gallery-main {
    background: #f5f0e8;
    aspect-ratio: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    position: sticky;
    top: 90px;
  }
  .gallery-main img {
    max-width: 85%;
    max-height: 85%;
    object-fit: contain;
    animation: floatIn 0.8s ease both;
  }
  @keyframes floatIn {
    from { opacity: 0; transform: translateY(30px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* Story Side */
  .atmosphere-quote {
    font-family: var(--font-serif);
    font-size: 0.85rem;
    font-style: italic;
    color: var(--color-gold);
    line-height: 1.8;
    margin-bottom: 1.5rem;
    padding-left: 1rem;
    border-left: 2px solid var(--color-gold);
  }
  .brand-heading {
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    color: var(--color-accent);
    text-transform: uppercase;
    font-weight: 600;
    margin-bottom: 0.3rem;
  }
  .watch-title {
    font-size: 1.3rem;
    font-weight: 400;
    line-height: 1.6;
    margin-bottom: 1rem;
  }
  .price-row {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin-bottom: 1.5rem;
  }
  .price-current { font-family: var(--font-serif); font-size: 1.4rem; font-weight: 700; color: var(--color-accent); }
  .price-original { font-size: 0.85rem; color: #bbb; text-decoration: line-through; }
  .price-discount {
    background: var(--color-accent); color: white;
    padding: 2px 8px; font-size: 0.65rem; font-weight: 700;
  }

  .narrative p {
    font-size: 0.82rem;
    color: #555;
    line-height: 2;
    margin-bottom: 1rem;
  }
  .narrative-extended { font-style: italic; color: var(--color-muted) !important; font-size: 0.8rem !important; }

  /* Specs */
  /* Action Buttons */
  .action-buttons {
    display: flex;
    gap: 0.8rem;
    margin: 1.5rem 0 0.8rem;
  }
  .btn-add-cart, .btn-buy-now {
    flex: 1;
    padding: 0.8rem 1rem;
    font-size: 0.82rem;
    border: none;
    cursor: pointer;
    font-family: var(--font-sans);
    transition: all 0.2s;
    letter-spacing: 0.05em;
  }
  .btn-add-cart {
    background: var(--color-bg);
    color: var(--color-text);
    border: 1px solid var(--color-text);
  }
  .btn-add-cart:hover {
    background: var(--color-border);
  }
  .btn-buy-now {
    background: var(--color-text);
    color: white;
  }
  .btn-buy-now:hover {
    opacity: 0.85;
  }
  .promo-banner {
    background: #f5f0e8;
    padding: 0.8rem;
    font-size: 0.75rem;
    color: #555;
    line-height: 1.6;
    margin-bottom: 0.5rem;
  }

  .specs {
    border-top: 1px solid var(--color-border);
    padding-top: 1.2rem;
    margin-top: 0.5rem;
  }
  .specs h3 {
    font-family: var(--font-serif);
    font-size: 0.78rem;
    font-weight: 600;
    margin-bottom: 0.8rem;
  }
  .specs-grid { display: grid; gap: 0.3rem; }
  .spec-row {
    display: flex;
    justify-content: space-between;
    padding: 0.3rem 0;
    border-bottom: 1px dashed rgba(229,221,208,0.5);
  }
  .spec-label { font-size: 0.72rem; color: var(--color-muted); }
  .spec-value { font-size: 0.75rem; color: var(--color-text); font-weight: 400; }

  /* Related */
  .related-stories { 
    max-width: 1100px; 
    margin: 3rem auto 0; 
    padding: 0 2rem;
  }
  .related-header { margin-bottom: var(--spacing-lg); }
  .section-label {
    font-size: 0.65rem; letter-spacing: 0.25em; color: var(--color-gold);
    text-transform: uppercase; margin-bottom: 0.3rem; font-weight: 500;
  }
  .related-header h2 { margin-bottom: 0; }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }
  .related-card {
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    animation: fadeIn 0.5s ease both;
    animation-delay: calc(var(--i) * 0.07s);
  }
  .related-img {
    aspect-ratio: 1;
    background: #f5f0e8;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }
  .related-img img {
    max-width: 80%;
    max-height: 80%;
    object-fit: contain;
    transition: transform 0.4s;
  }
  .related-card:hover .related-img img { transform: scale(1.08); }
  .related-info { padding: 0.6rem 0; }
  .related-brand { font-size: 0.6rem; letter-spacing: 0.1em; color: var(--color-gold); text-transform: uppercase; font-weight: 600; }
  .related-info h4 { font-size: 0.78rem; font-weight: 400; line-height: 1.4; margin: 0.3rem 0; }
  .related-price { font-family: var(--font-serif); font-size: 0.85rem; font-weight: 600; color: var(--color-accent); }

  .back-cta {
    text-align: center;
    padding: var(--spacing-xl) 2rem;
  }
  .btn-outline {
    display: inline-block;
    border: 1px solid var(--color-text);
    padding: 0.8rem 2rem;
    text-decoration: none;
    color: var(--color-text);
    font-size: 0.78rem;
    transition: all 0.3s;
    font-family: var(--font-sans);
    letter-spacing: 0.05em;
  }
  .btn-outline:hover { background: var(--color-text); color: white; }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(12px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @media (max-width: 800px) {
    .story-detail { grid-template-columns: 1fr; gap: 1.5rem; }
    .gallery-main { position: static; }
    .related-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 600px) {
    .related-grid { grid-template-columns: 1fr; }
  }
</style>