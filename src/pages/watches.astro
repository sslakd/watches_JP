---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="腕時計" description="厳選された時計コレクション — それぞれに物語があります。">
  <div class="hero">
    <div class="subtitle">コレクション</div>
    <h1>あなたの物語を<br>見つけてください</h1>
    <p>職人技、伝統、そしてストーリー性を重視して選ばれた時計たち。</p>
  </div>
  <div class="card-grid" id="watches-grid"></div>
  <div style="text-align: center; padding: var(--spacing-xl) 0;"><p style="color: var(--color-muted);">毎日新しい物語が追加されています。</p></div>
</BaseLayout>
