---
import BaseLayout from '../layouts/BaseLayout.astro';
import products from '../data/products.json';
const brands = [...new Set(products.map(p => p.brand))].sort();
const categories = [...new Set(products.map(p => p.category))].sort();
const groups = [
  { label: '高級 — ¥300,000以上', watches: products.filter(p => p.price_usd >= 3000).slice(0, 4) },
  { label: 'ミッドレンジ — ¥30,000〜¥300,000', watches: products.filter(p => p.price_usd >= 300 && p.price_usd < 3000).slice(0, 4) },
  { label: 'エントリー — ¥30,000以下', watches: products.filter(p => p.price_usd < 300).slice(0, 8) },
].filter(g => g.watches.length > 0);
const spotlight = products.slice(10, 12);
---
<BaseLayout title="腕時計" description="厳選された時計たちの物語。日本が誇るセイコー、シチズン、カシオ、オリエントの時計を、価格帯とストーリーでお届けします。">
  <!-- Hero -->
  <section class="listing-hero">
    <div class="listing-hero-inner">
      <div class="hero-kicker">— 時計物語コレクション —</div>
      <h1>{products.length}本の時計<br>それぞれに物語がある</h1>
      <p>機械式の温もり、クォーツの正確さ、ソーラーの革新。<br>
      一本一本に、作り手の想いと持ち主のストーリーが刻まれています。</p>
    </div>
  </section>

  <!-- By Price Group — Storytelling Bands -->
  {groups.map((group, gi) => (
    <section class={`price-band ${gi % 2 === 0 ? 'band-light' : 'band-dark'}`}>
      <div class="band-header">
        <div class="band-number">{String(gi + 1).padStart(2, '0')}</div>
        <div>
          <h2>{group.label}</h2>
          <p class="band-sub">{group.watches.length}本の時計</p>
        </div>
      </div>
      <div class="band-grid">
        {group.watches.map((product, i) => (
          <a href={`/watches/${product.sku}`} class="band-card" style={`--i: ${i}`}>
            <div class="band-card-img">
              <img src={product.image} alt={product.name} loading="lazy" />
            </div>
            <div class="band-card-info">
              <div class="band-brand">{product.brand}</div>
              <h3>{product.name.length > 50 ? product.name.slice(0, 50) + '…' : product.name}</h3>
              <div class="band-card-footer">
                <span class="band-price">${product.price_usd.toLocaleString()}</span>
                <span class="band-link">詳細を見る →</span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </section>
  ))}

  <!-- All Watches — Full Grid -->
  <section class="all-watches">
    <div class="all-header">
      <div class="section-label">コレクション</div>
      <h2>すべての時計</h2>
      <div class="all-controls">
        <select class="sort-select">
          <option>おすすめ順</option>
          <option>価格の安い順</option>
          <option>価格の高い順</option>
          <option>ブランド順</option>
        </select>
        <span class="all-count">{products.length}本</span>
      </div>
    </div>
    <div class="all-grid">
      {products.slice(0, 48).map((product, i) => (
        <a href={`/watches/${product.sku}`} class="all-card" style={`--delay: ${(i % 12) * 0.04}s`}>
          <div class="all-img">
            <img src={product.image} alt={product.name} loading="lazy" />
            {product.price_usd < 50 && <span class="badge-spotlight">お手頃</span>}
          </div>
          <div class="all-info">
            <div class="all-brand">{product.brand}</div>
            <h4>{product.name.length > 45 ? product.name.slice(0, 45) + '…' : product.name}</h4>
            <span class="all-price">${product.price_usd.toLocaleString()}</span>
          </div>
        </a>
      ))}
    </div>
    <div class="pagination">
      <span class="page-current">1</span>
      <a href="#" class="page-link">2</a>
      <a href="#" class="page-link">3</a>
      <a href="#" class="page-link">次へ →</a>
    </div>
  </section>
</BaseLayout>

<style>
  .listing-hero {
    padding: 8rem 2rem 4rem;
    background: linear-gradient(to bottom, #f0ece4, var(--color-bg));
    text-align: center;
  }
  .listing-hero-inner { max-width: 700px; margin: 0 auto; }
  .listing-hero .hero-kicker {
    font-size: 0.65rem; letter-spacing: 0.25em; color: var(--color-gold);
    text-transform: uppercase; margin-bottom: 1rem; font-weight: 500;
  }
  .listing-hero h1 { margin-bottom: 1rem; }
  .listing-hero p { font-size: 0.85rem; color: var(--color-muted); line-height: 2; }

  /* Price Bands */
  .price-band { padding: var(--spacing-xl) 2rem; }
  .band-light { background: white; }
  .band-dark { background: var(--color-bg); }
  .band-header {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    max-width: 1200px;
    margin: 0 auto var(--spacing-lg);
  }
  .band-number {
    font-family: var(--font-serif);
    font-size: 2.5rem;
    color: var(--color-gold);
    opacity: 0.25;
    line-height: 1;
  }
  .band-header h2 { margin-bottom: 0.2rem; }
  .band-sub { font-size: 0.75rem; color: var(--color-muted); }

  .band-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
    max-width: 1200px;
    margin: 0 auto;
  }
  .band-card {
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    transition: all 0.3s;
    animation: fadeIn 0.5s ease both;
    animation-delay: calc(var(--i) * 0.08s);
  }
  .band-card:hover { transform: translateY(-4px); }
  .band-card-img {
    aspect-ratio: 1;
    background: #f5f0e8;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }
  .band-card-img img {
    max-width: 80%;
    max-height: 80%;
    object-fit: contain;
    transition: transform 0.5s;
  }
  .band-card:hover .band-card-img img { transform: scale(1.1); }
  .band-card-info { padding: 0.8rem 0; }
  .band-brand {
    font-size: 0.6rem; letter-spacing: 0.1em; color: var(--color-gold);
    text-transform: uppercase; font-weight: 600; margin-bottom: 0.2rem;
  }
  .band-card-info h3 {
    font-size: 0.82rem; font-weight: 400; line-height: 1.5;
    margin-bottom: 0.5rem; font-family: var(--font-sans);
  }
  .band-card-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .band-price { font-family: var(--font-serif); font-size: 0.95rem; font-weight: 600; color: var(--color-accent); }
  .band-link { font-size: 0.7rem; color: var(--color-muted); transition: color 0.3s; }
  .band-card:hover .band-link { color: var(--color-accent); }

  /* All Watches Grid */
  .all-watches { padding: var(--spacing-xl) 2rem var(--spacing-2xl); }
  .all-header {
    max-width: 1200px;
    margin: 0 auto var(--spacing-lg);
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    flex-wrap: wrap;
    gap: 1rem;
  }
  .all-header .section-label { font-size: 0.65rem; letter-spacing: 0.25em; color: var(--color-gold); text-transform: uppercase; font-weight: 500; }
  .all-header h2 { margin-bottom: 0; }
  .all-controls { display: flex; align-items: center; gap: 1rem; }
  .sort-select {
    padding: 0.4rem 0.8rem;
    border: 1px solid var(--color-border);
    background: white;
    font-size: 0.78rem;
    font-family: var(--font-sans);
    color: var(--color-text);
    cursor: pointer;
  }
  .all-count { font-size: 0.78rem; color: var(--color-muted); }

  .all-grid {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 1px;
    background: var(--color-border);
    max-width: 1200px;
    margin: 0 auto;
  }
  .all-card {
    text-decoration: none;
    color: inherit;
    background: white;
    display: flex;
    flex-direction: column;
    animation: fadeIn 0.4s ease both;
    animation-delay: var(--delay, 0s);
  }
  .all-img {
    position: relative;
    aspect-ratio: 1;
    background: #f5f0e8;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }
  .all-img img {
    max-width: 80%;
    max-height: 80%;
    object-fit: contain;
    transition: transform 0.4s;
  }
  .all-card:hover .all-img img { transform: scale(1.08); }
  .badge-spotlight {
    position: absolute;
    top: 6px; left: 6px;
    background: var(--color-text);
    color: white;
    padding: 2px 8px;
    font-size: 0.6rem;
    font-weight: 600;
    letter-spacing: 0.05em;
  }
  .all-info { padding: 0.6rem 0.8rem 0.8rem; }
  .all-brand { font-size: 0.55rem; letter-spacing: 0.1em; color: var(--color-gold); text-transform: uppercase; font-weight: 600; }
  .all-info h4 { font-size: 0.75rem; font-weight: 400; line-height: 1.4; margin: 0.3rem 0; font-family: var(--font-sans); }
  .all-price { font-family: var(--font-serif); font-size: 0.85rem; font-weight: 600; color: var(--color-accent); }

  /* Pagination */
  .pagination {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 0.3rem;
    padding: 2rem 0 0;
  }
  .page-current {
    background: var(--color-text);
    color: white;
    width: 32px; height: 32px;
    display: flex; align-items: center; justify-content: center;
    font-size: 0.78rem;
  }
  .page-link {
    color: var(--color-muted); text-decoration: none;
    font-size: 0.78rem; padding: 0.3rem 0.6rem;
  }
  .page-link:hover { color: var(--color-text); }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(15px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @media (max-width: 1000px) {
    .band-grid { grid-template-columns: repeat(2, 1fr); }
    .all-grid { grid-template-columns: repeat(3, 1fr); }
  }
  @media (max-width: 600px) {
    .band-grid { grid-template-columns: 1fr; }
    .all-grid { grid-template-columns: repeat(2, 1fr); }
  }
</style>