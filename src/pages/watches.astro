---
import BaseLayout from '../layouts/BaseLayout.astro';
import products from '../data/products.json';
import { translateProductName } from '../data/i18n.js';
import { toJPY } from '../data/jpyRate.js';

const visibleProducts = products.slice(0, 48).map((p) => ({ ...p, jpName: translateProductName(p.name), jpy: toJPY(p.price_usd) }));
const priceGroups = [
  { label: '3万円以下', intent: 'はじめての一本', watches: products.filter((p) => p.price_usd > 0 && p.price_usd < 300).slice(0, 4) },
  { label: '3万円から30万円', intent: '価値を重視', watches: products.filter((p) => p.price_usd >= 300 && p.price_usd < 3000).slice(0, 4) },
  { label: '30万円以上', intent: '記念品・コレクション', watches: products.filter((p) => p.price_usd >= 3000).slice(0, 4) },
].filter((group) => group.watches.length > 0).map((group) => ({
  ...group,
  watches: group.watches.map((p) => ({ ...p, jpName: translateProductName(p.name), jpy: toJPY(p.price_usd) })),
}));
---

<BaseLayout title="時計購入ガイド" description="時計の物語と購入判断をつなぐCreationWatches向けアフィリエイトガイド。">
  <section class="page-hero">
    <div class="container">
      <p class="eyebrow">Buying Guide Hub</p>
      <h1>{products.length}本の時計を、購入意図で整理。</h1>
      <p>価格帯、ブランド、用途から時計を理解し、気になるモデルはCreationWatchesで現在価格を確認できます。</p>
    </div>
  </section>

  <section class="price-groups">
    <div class="container">
      <div class="section-heading">
        <div><p class="eyebrow">検索意図</p><h2>価格帯から読む</h2></div>
      </div>
      <div class="group-grid">
        {priceGroups.map((group) => (
          <section class="group-panel">
            <div class="group-header"><span>{group.intent}</span><h3>{group.label}</h3></div>
            <div class="mini-list">
              {group.watches.map((watch) => (
                <a href={watch.url || '#'} class="mini-card" target="_blank" rel="noopener noreferrer">
                  <img src={watch.image} alt={watch.jpName} loading="lazy" />
                  <div>
                    <span>{watch.brand}</span>
                    <strong>{watch.jpName}</strong>
                    <em>¥{watch.jpy}</em>
                    <small>CreationWatchesで価格を確認</small>
                  </div>
                </a>
              ))}
            </div>
          </section>
        ))}
      </div>
    </div>
  </section>

  <section class="all-watches">
    <div class="container">
      <div class="section-heading">
        <div><p class="eyebrow">Affiliate Feed</p><h2>すべての購入ガイド</h2></div>
        <span class="count">{visibleProducts.length}本を表示</span>
      </div>
      <div class="watch-grid">
        {visibleProducts.map((watch) => (
          <a href={watch.url || '#'} class="watch-card" target="_blank" rel="noopener noreferrer">
            <div class="watch-image">
              {watch.price_usd > 0 && watch.price_usd < 300 && <span class="badge">Value</span>}
              <img src={watch.image} alt={watch.jpName} loading="lazy" />
            </div>
            <div class="watch-info">
              <span>{watch.brand}</span>
              <h3>{watch.jpName}</h3>
              <strong>¥{watch.jpy}</strong>
              <small>CreationWatchesで価格を確認</small>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .price-groups { padding: var(--spacing-xl) 0; background: var(--color-surface); }
  .section-heading { display: flex; justify-content: space-between; align-items: end; gap: 1.5rem; margin-bottom: 2rem; }
  .count { color: var(--color-muted); font-size: 0.82rem; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; }
  .group-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1px; background: var(--color-border); border: 1px solid var(--color-border); }
  .group-panel, .watch-card { background: var(--color-surface); }
  .group-header { padding: 1.25rem; border-bottom: 1px solid var(--color-border); }
  .group-header span, .mini-card span, .watch-info span { color: var(--color-gold); font-size: 0.62rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; }
  .group-header h3 { margin-top: 0.35rem; }
  .mini-list { display: grid; }
  .mini-card { display: grid; grid-template-columns: 74px 1fr; gap: 0.9rem; min-width: 0; padding: 1rem 1.25rem; color: inherit; text-decoration: none; border-bottom: 1px solid var(--color-border); }
  .mini-card img { width: 74px; height: 74px; object-fit: contain; background: var(--color-soft); }
  .mini-card div { min-width: 0; display: grid; gap: 0.2rem; align-content: center; }
  .mini-card strong { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; font-size: 0.84rem; font-weight: 400; }
  .mini-card em { color: var(--color-accent); font-family: var(--font-serif); font-size: 0.96rem; font-style: normal; }
  .mini-card small, .watch-info small { color: var(--color-muted); font-size: 0.65rem; font-weight: 700; letter-spacing: 0.04em; text-transform: uppercase; }
  .all-watches { padding: var(--spacing-xl) 0 var(--spacing-2xl); }
  .watch-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1px; background: var(--color-border); border: 1px solid var(--color-border); }
  .watch-card { display: flex; flex-direction: column; min-width: 0; color: inherit; text-decoration: none; }
  .watch-image { position: relative; display: grid; place-items: center; aspect-ratio: 1; padding: 1rem; background: #f7f3ed; }
  .watch-image img { width: 100%; height: 100%; object-fit: contain; }
  .badge { position: absolute; top: 0.7rem; left: 0.7rem; background: var(--color-text); color: white; padding: 0.25rem 0.45rem; font-size: 0.58rem; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; }
  .watch-info { display: grid; gap: 0.35rem; padding: 1rem; }
  .watch-info h3 { display: -webkit-box; min-height: 3.4em; overflow: hidden; font-family: var(--font-sans); font-size: 0.86rem; font-weight: 400; line-height: 1.7; -webkit-line-clamp: 2; -webkit-box-orient: vertical; }
  .watch-info strong { color: var(--color-accent); font-family: var(--font-serif); font-size: 1rem; }
  @media (max-width: 1040px) { .group-grid { grid-template-columns: 1fr; } .watch-grid { grid-template-columns: repeat(3, 1fr); } }
  @media (max-width: 720px) { .section-heading { align-items: start; flex-direction: column; } .watch-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 480px) { .watch-grid { grid-template-columns: 1fr; } }
</style>
