---
export interface Props {
  title: string;
  description: string;
}
const { title, description } = Astro.props;
const canonicalPath = Astro.url.pathname
  .replace(/\/index\.html$/, '/')
  .replace(/\.html$/, '');
const canonicalUrl = new URL(canonicalPath || '/', 'https://tokeimonogatari.com').toString();
---

<!DOCTYPE html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | 時計物語</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:url" content={canonicalUrl} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Noto+Serif+JP:wght@300;400;600;700&family=Zen+Kaku+Gothic+New:wght@300;400;500;700&display=swap" rel="stylesheet" />
    <style>
      :root {
        --font-serif: "Noto Serif JP", "Yu Mincho", serif;
        --font-sans: "Zen Kaku Gothic New", "Hiragino Sans", sans-serif;
        --color-bg: #faf8f5;
        --color-surface: #ffffff;
        --color-soft: #f0ece4;
        --color-text: #1a1a1a;
        --color-subtle: #4f4a45;
        --color-accent: #8b1a1a;
        --color-gold: #9d7a24;
        --color-muted: #7d7770;
        --color-border: #e5ddd0;
        --spacing-xl: 6rem;
        --spacing-2xl: 9rem;
        --container: 1180px;
      }
      * { box-sizing: border-box; }
      body {
        margin: 0;
        font-family: var(--font-sans);
        font-weight: 300;
        color: var(--color-text);
        background: var(--color-bg);
        line-height: 2;
        letter-spacing: 0.03em;
      }
      img { display: block; max-width: 100%; }
      p { margin: 0; }
      h1, h2, h3, h4 { margin: 0; font-family: var(--font-serif); font-weight: 400; }
      h1 { font-size: clamp(2rem, 5vw, 4.4rem); line-height: 1.28; }
      h2 { font-size: clamp(1.7rem, 4vw, 3rem); line-height: 1.35; }
      .container { width: min(var(--container), calc(100% - 2rem)); margin: 0 auto; }
      .site-header {
        position: sticky;
        top: 0;
        z-index: 20;
        background: rgba(250,248,245,0.92);
        border-bottom: 1px solid var(--color-border);
        backdrop-filter: blur(14px);
      }
      nav { min-height: 72px; display: flex; justify-content: space-between; align-items: center; gap: 1.5rem; }
      .logo { font-family: var(--font-serif); font-size: 1.25rem; color: var(--color-text); text-decoration: none; letter-spacing: 0.08em; }
      .logo span { color: var(--color-gold); }
      .nav-links { display: flex; gap: 1.25rem; align-items: center; }
      .nav-links a {
        color: var(--color-muted);
        text-decoration: none;
        font-size: 0.74rem;
        font-weight: 500;
        letter-spacing: 0.08em;
        text-transform: uppercase;
      }
      .nav-links a:hover { color: var(--color-text); }
      .eyebrow {
        color: var(--color-gold);
        font-size: 0.68rem;
        font-weight: 700;
        letter-spacing: 0.16em;
        text-transform: uppercase;
      }
      .btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 44px;
        border: 1px solid var(--color-text);
        padding: 0.8rem 1.35rem;
        color: var(--color-text);
        text-decoration: none;
        font-size: 0.74rem;
        font-weight: 700;
        letter-spacing: 0.08em;
      }
      .btn:hover, .btn-primary { background: var(--color-text); color: white; }
      .btn-primary:hover { background: var(--color-accent); border-color: var(--color-accent); }
      .page-hero { padding: 7rem 0 4rem; text-align: center; background: linear-gradient(180deg, var(--color-soft), var(--color-bg)); }
      .page-hero p { max-width: 680px; margin: 1.25rem auto 0; color: var(--color-muted); }
      footer { padding: 4rem 0; border-top: 1px solid var(--color-border); color: var(--color-muted); background: var(--color-surface); font-size: 0.82rem; }
      .footer-inner { display: flex; justify-content: space-between; align-items: flex-start; gap: 2rem; }
      footer .brand { font-family: var(--font-serif); font-size: 1.15rem; color: var(--color-text); margin-bottom: 0.35rem; }
      @media (max-width: 700px) {
        nav { min-height: 64px; flex-direction: column; align-items: flex-start; justify-content: center; gap: 0.5rem; padding: 0.75rem 0; }
        .nav-links { width: 100%; justify-content: space-between; gap: 0.75rem; }
        .footer-inner { flex-direction: column; }
      }
    </style>
    <style is:global>
      main > .story-article {
        max-width: 920px !important;
        padding: 5rem 1.5rem 8rem !important;
      }
      main > .story-article .story-header {
        max-width: 820px;
        margin: 0 auto 4rem !important;
      }
      main > .story-article .story-header h1 {
        font-size: 3.7rem !important;
        line-height: 1.35 !important;
      }
      main > .story-article .story-hero-img {
        min-height: 620px !important;
        margin: 0 0 5rem !important;
        padding: 4rem !important;
        display: grid !important;
        place-items: center !important;
        overflow: hidden;
        background: #e8ede9 !important;
        border: 0 !important;
      }
      main > .story-article .story-hero-img img {
        width: auto !important;
        max-width: 88% !important;
        height: 520px !important;
        max-height: 520px !important;
        object-fit: contain !important;
      }
      main > .story-article .story-hero-img img[src^="http"] {
        mix-blend-mode: multiply;
      }
      main > .story-article .story-body {
        max-width: 720px;
        margin: 0 auto;
      }
      main > .story-article .story-lede {
        margin-bottom: 4rem !important;
        padding-left: 1.5rem !important;
        font-size: 1.08rem !important;
      }
      main > .story-article .story-body h2 {
        margin-top: 4.5rem !important;
        font-size: 1.75rem !important;
      }
      main > .story-article .story-quote {
        margin: 4rem 0 !important;
        padding: 2.5rem 3rem !important;
        border-radius: 0 !important;
      }
      main > .story-article .story-specs {
        margin: 4rem 0 !important;
        border-radius: 0 !important;
        background: transparent !important;
      }
      main > .story-article .story-cta {
        margin-top: 5rem !important;
        padding: 3.5rem 2rem !important;
        border-radius: 0 !important;
        border-top: 1px solid var(--color-border);
        border-bottom: 1px solid var(--color-border);
        background: #f0ece4 !important;
      }
      main > .story-article .story-cta a {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 46px;
        padding: .85rem 1.25rem;
        color: #fff;
        background: #293a36;
        border: 1px solid #293a36;
        text-decoration: none;
        font-size: .76rem;
        font-weight: 700;
        letter-spacing: .08em;
      }
      @media (max-width: 700px) {
        main > .story-article { padding: 3rem .75rem 5rem !important; }
        main > .story-article .story-header h1 { font-size: 2.35rem !important; }
        main > .story-article .story-hero-img {
          min-height: 460px !important;
          margin-bottom: 3rem !important;
          padding: 2rem 1rem !important;
        }
        main > .story-article .story-hero-img img {
          max-width: 100% !important;
          height: 400px !important;
        }
        main > .story-article .story-body h2 { font-size: 1.5rem !important; }
        main > .story-article .story-quote { padding: 1.5rem !important; }
      }
    </style>
  </head>
  <body>
    <header class="site-header">
      <div class="container">
        <nav aria-label="メインナビゲーション">
          <a href="/" class="logo"><span>時計</span>物語</a>
          <div class="nav-links">
            <a href="/">物語</a>
            <a href="/watches">購入ガイド</a>
            <a href="/about">このサイト</a>
          </div>
        </nav>
      </div>
    </header>
    <main><slot /></main>
    <footer>
      <div class="container footer-inner">
        <div>
          <div class="brand">時計物語</div>
          <p>時計の物語、選び方、そしてCreationWatchesへの価格リンク。</p>
        </div>
        <p>アフィリエイト開示: CreationWatchesリンク経由の購入で、当サイトが手数料を受け取る場合があります。&copy; 2026 時計物語。</p>
      </div>
    </footer>
  </body>
</html>
